<!-- components/goods-card/goods-card.wxml - 商品卡片组件 -->
<view class="goods-card {{mode === 'list' ? 'list-mode' : 'grid-mode'}}" bindtap="onCardTap">
  <!-- 商品图片 -->
  <view class="card-image-wrap">
    <image
      class="card-image"
      src="{{goods.images[0] || '/images/placeholder.png'}}"
      mode="aspectFill"
      lazy-load
      data-url="{{goods.images[0]}}"
      bindtap="onImageTap"
    />
    <!-- 成色标签 -->
    <view class="condition-tag" wx:if="{{goods.condition}}">
      {{goods.condition}}
    </view>
    <!-- 状态标签 -->
    <view class="status-badge" wx:if="{{goods.status === 'sold'}}">已售</view>
    <view class="status-badge off" wx:if="{{goods.status === 'off'}}">已下架</view>
  </view>

  <!-- 商品信息 -->
  <view class="card-info">
    <text class="card-title">{{goods.title}}</text>

    <view class="card-price-row">
      <text class="card-price">¥{{goods.price}}</text>
      <text class="card-unit" wx:if="{{goods.priceUnit && goods.priceUnit !== '件'}}">/{{goods.priceUnit}}</text>
    </view>

    <view class="card-meta">
      <view class="meta-left">
        <text class="meta-time" wx:if="{{goods.createTimeFormatted}}">{{goods.createTimeFormatted}}</text>
      </view>
      <view class="favorite-btn {{goods.isFavorited ? 'active' : ''}}" catchtap="onFavoriteTap" wx:if="{{showFavoriteBtn}}">
        {{goods.isFavorited ? '❤️' : '🤍'}}
      </view>
    </view>
  </view>
</view>
