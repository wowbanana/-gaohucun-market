/* pages/category/category.wxss - 分类浏览 · 湖畔晨光 */

.category-page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: var(--color-bg-page);
}

.search-entry {
  padding: 14rpx 24rpx;
  background: var(--color-bg-card);
}

.search-bar {
  display: flex; align-items: center; background: var(--color-bg-input);
  border-radius: var(--radius-full); padding: 14rpx 24rpx;
}

.search-icon { font-size: 28rpx; margin-right: 10rpx; }
.search-placeholder { font-size: 26rpx; color: var(--color-text-tertiary); }

.category-layout { flex: 1; display: flex; overflow: hidden; }

.parent-sidebar {
  width: 180rpx; background: var(--color-bg-card); height: 100%;
  border-right: 1rpx solid var(--color-border-light);
}

.parent-item {
  padding: 26rpx 16rpx; text-align: center; position: relative;
}

.parent-item.active { background: var(--color-bg-page); }

.parent-item.active::before {
  content: ''; position: absolute; left: 0; top: 50%; transform: translateY(-50%);
  width: 5rpx; height: 32rpx; background: var(--color-primary); border-radius: 0 4rpx 4rpx 0;
}

.parent-name { font-size: 26rpx; color: var(--color-text-secondary); }
.parent-item.active .parent-name { color: var(--color-primary); font-weight: 600; }

.content-area { flex: 1; height: 100%; background: var(--color-bg-page); }

.sub-categories { padding: 14rpx 0; border-bottom: 1rpx solid var(--color-border-light); background: var(--color-bg-card); }
.sub-scroll { white-space: nowrap; padding: 0 16rpx; }

.sub-tag {
  display: inline-flex; flex-direction: column; align-items: center;
  padding: 10rpx 20rpx; margin-right: 10rpx; border-radius: var(--radius-md);
  background: var(--color-bg-tag);
}

.sub-tag.active { background: var(--color-primary-light); }
.sub-icon { font-size: 34rpx; margin-bottom: 4rpx; }
.sub-name { font-size: 22rpx; color: var(--color-text-secondary); }
.sub-tag.active .sub-name { color: var(--color-primary); font-weight: 600; }

.goods-list { padding: 14rpx; display: flex; flex-wrap: wrap; }

.goods-item {
  width: calc(50% - 14rpx);
  margin: 7rpx;
  background: var(--color-bg-card); border-radius: var(--radius-xl);
  overflow: hidden; box-shadow: var(--shadow-xs);
}

.goods-img-wrap { position: relative; width: 100%; height: 260rpx; }
.goods-image { width: 100%; height: 100%; background: var(--color-bg-tag); }

/* "我发布的" 标记 */
.my-goods-badge {
  position: absolute;
  top: 0;
  left: 0;
  padding: 4rpx 14rpx;
  background: rgba(61, 122, 124, 0.85);
  border-radius: 0 0 12rpx 0;
}
.my-goods-badge text {
  font-size: 20rpx;
  color: #fff;
  font-weight: 500;
}
.goods-info { padding: 14rpx; }

.goods-title {
  font-size: 26rpx; color: var(--color-text-primary);
  display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical;
  overflow: hidden; line-height: 1.4;
}

.goods-meta { margin-top: 8rpx; display: flex; align-items: baseline; }
.goods-price { font-size: 30rpx; font-weight: 700; color: var(--color-price); }
.goods-unit { font-size: 22rpx; color: var(--color-text-tertiary); margin-left: 2rpx; }

.goods-bottom { display: flex; justify-content: space-between; align-items: center; margin-top: 6rpx; }
.goods-condition {
  font-size: 22rpx; color: var(--color-primary); background: var(--color-primary-light);
  padding: 2rpx 10rpx; border-radius: var(--radius-full);
}
.goods-location { font-size: 22rpx; color: var(--color-text-tertiary); }

.loading-status { padding: 30rpx 0; text-align: center; }
.loading-more { display: flex; align-items: center; justify-content: center; gap: 10rpx; font-size: 26rpx; color: var(--color-text-tertiary); }
.loading-spinner { width: 32rpx; height: 32rpx; border: 3rpx solid var(--color-border-light); border-top-color: var(--color-primary); border-radius: 50%; animation: spin 0.8s linear infinite; }
@keyframes spin { to { transform: rotate(360deg); } }
.no-more { font-size: 24rpx; color: var(--color-text-tertiary); }
.empty-result { display: flex; flex-direction: column; align-items: center; padding: 60rpx 0; }
.empty-icon { font-size: 80rpx; margin-bottom: 16rpx; }
.empty-text { font-size: 28rpx; color: var(--color-text-tertiary); }
