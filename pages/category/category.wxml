<!-- pages/category/category.wxml - 分类浏览页 -->
<view class="category-page">
  <!-- 搜索入口 -->
  <view class="search-entry" bindtap="onGoSearch">
    <view class="search-bar">
      <text class="search-icon">🔍</text>
      <text class="search-placeholder">搜索你想要的宝贝...</text>
    </view>
  </view>

  <!-- 顶部父分类 tabs -->
  <view class="parent-tabs-wrap">
    <scroll-view class="parent-tabs" scroll-x enhanced show-scrollbar="{{false}}">
      <view class="parent-tabs-inner">
        <view
          class="parent-tab {{currentParent === item.id ? 'parent-tab--on' : ''}}"
          wx:for="{{parentCategories}}"
          wx:key="id"
          data-id="{{item.id}}"
          bindtap="onParentTap"
        >
          <text class="parent-tab-icon">{{item.icon}}</text>
          <text class="parent-tab-name">{{item.name}}</text>
        </view>
      </view>
    </scroll-view>
  </view>

  <!-- 子分类图标网格（仅在有子分类时显示） -->
  <view class="sub-grid-wrap" wx:if="{{showSubGrid}}">
    <view class="sub-grid">
      <view
        class="sub-cell {{currentSubCategory === item.id ? 'sub-cell--on' : ''}}"
        wx:for="{{subCategories}}"
        wx:key="id"
        data-id="{{item.id}}"
        bindtap="onSubTap"
      >
        <view class="sub-cell-icon-wrap">
          <text class="sub-cell-icon">{{item.icon}}</text>
        </view>
        <text class="sub-cell-name">{{item.name}}</text>
      </view>
    </view>
  </view>

  <!-- 商品双列网格 -->
  <scroll-view
    class="goods-scroll"
    scroll-y
    bindscrolltolower="onReachBottom"
    lower-threshold="100"
  >
    <view class="goods-grid">
      <view
        class="goods-card"
        wx:for="{{goodsList}}"
        wx:key="_id"
        data-id="{{item._id}}"
        bindtap="onGoodsTap"
      >
        <view class="goods-card-img-wrap">
          <image class="goods-card-img" src="{{item.coverUrl || '/images/default-goods.png'}}" mode="aspectFill" />
          <view class="my-goods-badge" wx:if="{{item.isMyGoods}}">
            <text>我发布的</text>
          </view>
        </view>
        <view class="goods-card-body">
          <text class="goods-card-title">{{item.title}}</text>
          <view class="goods-card-meta">
            <text class="goods-card-price">¥{{item.price}}</text>
            <text class="goods-card-unit" wx:if="{{item.priceUnit}}">/{{item.priceUnit}}</text>
          </view>
          <view class="goods-card-footer">
            <text class="goods-card-cond">{{item.condition || '八成新'}}</text>
            <text class="goods-card-time">{{item.publishTimeText || '刚刚'}}</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 加载状态 -->
    <view class="load-status">
      <view class="load-status-row" wx:if="{{loading}}">
        <view class="load-spinner"></view>
        <text>加载中...</text>
      </view>
      <view class="load-status-row" wx:elif="{{!hasMore && goodsList.length > 0}}">
        <text class="load-end">— 没有更多了 —</text>
      </view>
      <view class="load-status-empty" wx:elif="{{!loading && goodsList.length === 0}}">
        <text class="empty-icon">📦</text>
        <text class="empty-text">该分类下暂无商品</text>
      </view>
    </view>

    <!-- 底部安全区 -->
    <view class="safe-bottom"></view>
  </scroll-view>
</view>
