/* pages/search/search.wxss - 搜索页 · 湖畔晨光 */

.search-page { min-height: 100vh; background: var(--color-bg-page); }

.search-header {
  display: flex; align-items: center; padding: 14rpx 24rpx;
  background: var(--color-bg-card); gap: 14rpx;
}

.search-input-wrap {
  flex: 1; display: flex; align-items: center; background: var(--color-bg-input);
  border-radius: var(--radius-full); padding: 10rpx 24rpx;
}

.search-icon { font-size: 28rpx; margin-right: 10rpx; }
.search-input { flex: 1; font-size: 28rpx; color: var(--color-text-primary); }

.clear-btn {
  width: 34rpx; height: 34rpx; background: var(--color-border);
  border-radius: 50%; display: flex; align-items: center; justify-content: center;
  font-size: 18rpx; color: #FFFFFF;
}

.search-cancel { font-size: 28rpx; color: var(--color-primary); white-space: nowrap; }

.search-suggest { padding: 24rpx; }

.section-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 18rpx; }
.section-title { font-size: 30rpx; font-weight: 600; color: var(--color-text-primary); }
.clear-history { font-size: 24rpx; color: var(--color-text-tertiary); }

.history-section { margin-bottom: 36rpx; }
.history-tags { display: flex; flex-wrap: wrap; gap: 14rpx; }

.history-tag {
  padding: 10rpx 22rpx; background: var(--color-bg-card);
  border-radius: var(--radius-full); font-size: 26rpx; color: var(--color-text-secondary);
}

.hot-tags { display: flex; flex-direction: column; gap: 6rpx; }

.hot-tag {
  display: flex; align-items: center; padding: 14rpx 18rpx;
  background: var(--color-bg-card); border-radius: var(--radius-md);
}

.hot-rank {
  width: 38rpx; height: 38rpx; display: flex; align-items: center;
  justify-content: center; font-size: 24rpx; color: var(--color-text-tertiary);
  font-weight: 600; margin-right: 14rpx;
}

.hot-rank.top { color: var(--color-price); }
.hot-text { font-size: 28rpx; color: var(--color-text-secondary); }

.filter-bar {
  display: flex; align-items: center; justify-content: space-between;
  padding: 14rpx 24rpx; background: var(--color-bg-card);
  border-bottom: 1rpx solid var(--color-border-light);
}

.sort-options { display: flex; gap: 32rpx; }

.sort-item {
  font-size: 26rpx; color: var(--color-text-secondary); padding: 6rpx 0; position: relative;
}

.sort-item.active { color: var(--color-primary); font-weight: 600; }

.sort-item.active::after {
  content: ''; position: absolute; bottom: 0; left: 50%; transform: translateX(-50%);
  width: 28rpx; height: 4rpx; background: var(--color-primary); border-radius: var(--radius-full);
}

.filter-btn {
  font-size: 26rpx; color: var(--color-text-secondary); padding: 6rpx 18rpx;
  border: 2rpx solid var(--color-border); border-radius: var(--radius-full);
}

.filter-btn.active { color: var(--color-primary); border-color: var(--color-primary); background: var(--color-primary-light); }

.filter-panel { background: var(--color-bg-card); padding: 24rpx; border-bottom: 1rpx solid var(--color-border); }
.filter-label { font-size: 26rpx; color: var(--color-text-secondary); margin-bottom: 14rpx; display: block; }
.filter-options { display: flex; flex-wrap: wrap; gap: 14rpx; }

.filter-option {
  padding: 8rpx 22rpx; background: var(--color-bg-tag);
  border-radius: var(--radius-full); font-size: 24rpx; color: var(--color-text-secondary);
}

.filter-option.active { background: var(--color-primary-light); color: var(--color-primary); font-weight: 500; }

.goods-list { padding: 14rpx; display: grid; grid-template-columns: repeat(2, 1fr); gap: 14rpx; }

.goods-item {
  background: var(--color-bg-card); border-radius: var(--radius-xl);
  overflow: hidden; box-shadow: var(--shadow-xs);
}

.goods-image { width: 100%; height: 260rpx; background: var(--color-bg-tag); }
.goods-info { padding: 14rpx; }

.goods-title {
  font-size: 26rpx; color: var(--color-text-primary);
  display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical;
  overflow: hidden; line-height: 1.4;
}

.goods-meta { margin-top: 8rpx; display: flex; align-items: baseline; }
.goods-price { font-size: 30rpx; font-weight: 700; color: var(--color-price); }
.goods-unit { font-size: 22rpx; color: var(--color-text-tertiary); margin-left: 2rpx; }

.goods-bottom { display: flex; justify-content: space-between; margin-top: 6rpx; }
.goods-condition {
  font-size: 22rpx; color: var(--color-primary); background: var(--color-primary-light);
  padding: 2rpx 10rpx; border-radius: var(--radius-full);
}
.goods-location { font-size: 22rpx; color: var(--color-text-tertiary); }

.empty-result { display: flex; flex-direction: column; align-items: center; padding: 100rpx 0; }
.empty-icon { font-size: 80rpx; margin-bottom: 16rpx; }
.empty-text { font-size: 30rpx; color: var(--color-text-secondary); margin-bottom: 8rpx; }
.empty-hint { font-size: 26rpx; color: var(--color-text-tertiary); }

.loading-status { display: flex; align-items: center; justify-content: center; gap: 10rpx; padding: 30rpx 0; font-size: 26rpx; color: var(--color-text-tertiary); }
.loading-spinner { width: 32rpx; height: 32rpx; border: 3rpx solid var(--color-border-light); border-top-color: var(--color-primary); border-radius: 50%; animation: spin 0.8s linear infinite; }
@keyframes spin { to { transform: rotate(360deg); } }
.no-more { text-align: center; padding: 30rpx 0; font-size: 24rpx; color: var(--color-text-tertiary); }
