<!--pages/wanted-detail/wanted-detail.wxml - 求购详情页-->
<view class="page-container">
  <!-- 加载状态 -->
  <view class="loading-container" wx:if="{{loading}}">
    <text class="loading-text">加载中...</text>
  </view>

  <block wx:if="{{!loading && wanted}}">
    <!-- 求购信息 -->
    <view class="wanted-section">
      <!-- 状态标签 -->
      <view class="status-tag status-tag--{{wanted.status}}">
        <text>{{wanted.statusText}}</text>
      </view>
      
      <!-- 标题 -->
      <text class="wanted-title">{{wanted.title}}</text>
      
      <!-- 预算 -->
      <view class="budget-section">
        <text class="budget-label">预算：</text>
        <text class="budget-value">{{wanted.budgetText}}</text>
      </view>
      
      <!-- 分类 -->
      <view class="info-item">
        <text class="info-label">分类</text>
        <text class="info-value">{{wanted.categoryName || '未分类'}}</text>
      </view>
      
      <!-- 位置 -->
      <view class="info-item">
        <text class="info-label">位置</text>
        <text class="info-value">📍 {{wanted.locationGroup || '未知'}}</text>
      </view>
    </view>

    <!-- 求购描述 -->
    <view class="description-section" wx:if="{{wanted.description}}">
      <view class="section-header">
        <text class="section-title">求购描述</text>
      </view>
      <text class="description-content">{{wanted.description}}</text>
    </view>

    <!-- 买家信息 -->
    <view class="buyer-section">
      <view class="section-header">
        <text class="section-title">买家信息</text>
      </view>
      <view class="buyer-info">
        <image class="buyer-avatar" src="{{wanted.buyerAvatar || '/images/default-avatar.png'}}" mode="aspectFill"></image>
        <view class="buyer-detail">
          <text class="buyer-name">{{wanted.buyerName || '匿名用户'}}</text>
          <text class="buyer-time">{{wanted.publishTimeText}}</text>
        </view>
      </view>
    </view>

    <!-- 响应按钮 -->
    <view class="action-section" wx:if="{{wanted.status === 'open'}}">
      <button 
        class="btn btn-primary btn-block btn-lg" 
        bindtap="onRespondTap"
        disabled="{{hasResponded}}"
      >
        {{hasResponded ? '已响应' : '我有，联系买家'}}
      </button>
      
      <view class="contact-buttons" wx:if="{{!hasResponded}}">
        <button class="btn btn-secondary contact-btn" bindtap="onCallTap">
          📞 打电话
        </button>
        <button class="btn btn-secondary contact-btn" bindtap="onCopyWechatTap">
          💬 复制微信号
        </button>
      </view>
    </view>
  </block>

  <!-- 错误状态 -->
  <view class="error-state" wx:if="{{!loading && !wanted}}">
    <text class="error-text">求购不存在或已删除</text>
    <button class="btn btn-primary" bindtap="onBackHome">返回求购广场</button>
  </view>
</view>
