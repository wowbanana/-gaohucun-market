/* pages/index/index.wxss - 首页 · 湖畔晨光 */

/* ========== 页面基底 ========== */
.page {
  min-height: 100vh;
  background: #F7F4F0;
  padding-bottom: 20rpx;
}

/* ========== 顶部横幅 ========== */
.hero {
  position: relative;
  background: linear-gradient(160deg, #3D7A7C 0%, #5A9FA0 50%, #8BC4A0 100%);
  padding: 60rpx 32rpx 80rpx;
  overflow: hidden;
}
.hero__inner {
  position: relative; z-index: 1;
}
.hero__title {
  display: block;
  font-size: 48rpx; font-weight: 700;
  color: #fff; letter-spacing: 4rpx;
  text-shadow: 0 2rpx 8rpx rgba(0,0,0,0.12);
}
.hero__sub {
  display: block;
  font-size: 26rpx;
  color: rgba(255,255,255,0.75);
  margin-top: 10rpx; letter-spacing: 2rpx;
}

/* 搜索条 */
.hero__search {
  display: flex; align-items: center;
  margin-top: 32rpx;
  padding: 20rpx 28rpx;
  background: rgba(255,255,255,0.20);
  border-radius: 50rpx;
  backdrop-filter: blur(8rpx);
}
.hero__search-icon { font-size: 28rpx; margin-right: 12rpx; }
.hero__search-text { font-size: 28rpx; color: rgba(255,255,255,0.8); }

/* 装饰波纹 */
.hero__wave {
  position: absolute; bottom: -2rpx; left: 0; right: 0;
  height: 48rpx;
  background: #F7F4F0;
  border-radius: 48rpx 48rpx 0 0;
}

/* ========== 公告栏（醒目大卡片）========== */
.bulletin {
  margin: -36rpx 24rpx 20rpx;
  padding: 24rpx 28rpx;
  background: linear-gradient(135deg, #FFF8F0 0%, #FFF3E4 100%);
  border-radius: 20rpx;
  border: 2rpx solid rgba(232,168,64,0.25);
  box-shadow: 0 4rpx 20rpx rgba(232,168,64,0.15);
  position: relative;
  z-index: 2;
}
.bulletin__header {
  display: flex; align-items: center; justify-content: space-between;
  margin-bottom: 16rpx;
}
.bulletin__badge {
  display: inline-flex; align-items: center; gap: 8rpx;
  font-size: 22rpx; font-weight: 600; color: #E8A840;
  background: rgba(232,168,64,0.12);
  padding: 6rpx 18rpx; border-radius: 99rpx;
}
.bulletin__badge-dot {
  width: 10rpx; height: 10rpx; border-radius: 50%;
  background: #E8A840;
  animation: pulse-dot 1.5s ease-in-out infinite;
}
@keyframes pulse-dot {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.3; }
}
.bulletin__count {
  font-size: 22rpx; color: #C4A060;
}
.bulletin__swiper {
  height: 50rpx;
}
.bulletin__item {
  display: flex; align-items: center; height: 50rpx;
}
.bulletin__tag {
  flex-shrink: 0;
  display: inline-flex; align-items: center;
  padding: 4rpx 16rpx;
  border-radius: 6rpx;
  font-size: 20rpx; font-weight: 600; color: #3D7A7C;
  background: rgba(61,122,124,0.10);
  margin-right: 16rpx;
}
.bulletin__tag--urgent {
  color: #DC2626;
  background: rgba(220,38,38,0.10);
}
.bulletin__title {
  flex: 1;
  font-size: 28rpx; font-weight: 500; color: #2C2416;
  overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
}
.bulletin__arrow {
  flex-shrink: 0;
  font-size: 32rpx; color: #C4A060;
  margin-left: 8rpx;
}

/* ========== 分类标签 ========== */
.cat-scroll {
  margin: 16rpx 0 8rpx;
  white-space: nowrap;
}
.cat-list {
  display: inline-flex;
  padding: 0 24rpx;
  gap: 14rpx;
}
.cat-chip {
  flex-shrink: 0;
  display: inline-flex; align-items: center; justify-content: center;
  padding: 16rpx 32rpx;
  border-radius: 99rpx;
  background: #fff;
  font-size: 28rpx; color: #6B6255;
  box-shadow: 0 1rpx 6rpx rgba(44,36,22,0.04);
  transition: all 0.2s;
}
.cat-chip--on {
  background: #3D7A7C; color: #fff;
  font-weight: 600;
  box-shadow: 0 4rpx 16rpx rgba(61,122,124,0.30);
}

/* ========== 排序 ========== */
.sort-row {
  display: flex;
  padding: 12rpx 24rpx 16rpx;
}
.sort-tab {
  flex: 1;
  text-align: center;
  font-size: 26rpx; color: #A09888;
  padding: 8rpx 0;
  border-bottom: 2rpx solid transparent;
  transition: all 0.2s;
  white-space: nowrap;
}
.sort-tab--on {
  color: #3D7A7C; font-weight: 600;
  border-bottom-color: #3D7A7C;
}

/* "我发布的" 标记（商品卡片左上角） */
.my-goods-tag {
  position: absolute;
  top: 0;
  left: 0;
  padding: 4rpx 14rpx;
  background: rgba(61, 122, 124, 0.85);
  border-radius: 0 0 12rpx 0;
  z-index: 2;
}
.my-goods-tag text {
  font-size: 20rpx;
  color: #fff;
  font-weight: 500;
}

/* ========== 商品双列网格 ========== */
.goods-grid {
  display: flex; flex-wrap: wrap;
  padding: 0 10rpx;
  /* 不用 gap（iOS 旧版 flex 不兼容），改用 margin 实现间距 */
}
.goods-card {
  width: calc(50% - 20rpx);
  margin: 0 10rpx 20rpx;
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(44,36,22,0.04);
  transition: transform 0.15s;
  box-sizing: border-box;
}
.goods-card:active { transform: scale(0.97); }

/* 图片 */
.goods-card__img-wrap {
  position: relative;
  width: 100%; height: 340rpx;
  background: #E6E1DA;
}
.goods-card__img { width: 100%; height: 100%; }
.goods-card__price-tag {
  position: absolute;
  left: 12rpx; bottom: 12rpx;
  display: flex; align-items: baseline;
  padding: 6rpx 16rpx;
  background: rgba(44,36,22,0.65);
  border-radius: 8rpx;
  backdrop-filter: blur(4rpx);
}
.goods-card__price {
  font-size: 28rpx; font-weight: 700; color: #fff;
}
.goods-card__unit {
  font-size: 20rpx; color: rgba(255,255,255,0.75);
  margin-left: 4rpx;
}

/* 信息 */
.goods-card__body {
  padding: 16rpx 18rpx 20rpx;
}
.goods-card__title {
  display: -webkit-box;
  font-size: 28rpx; color: #2C2416; font-weight: 500;
  line-height: 1.5; max-height: 84rpx;
  overflow: hidden; text-overflow: ellipsis;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  margin-bottom: 12rpx;
}
.goods-card__footer {
  display: flex; align-items: center; justify-content: space-between;
}
.goods-card__cond {
  font-size: 22rpx; color: #3D7A7C;
  padding: 4rpx 14rpx; background: #EEF6F6;
  border-radius: 99rpx;
}
.goods-card__time { font-size: 22rpx; color: #A09888; }

/* ========== 加载/结束 ========== */
.load-more {
  display: flex; align-items: center; justify-content: center;
  padding: 40rpx 32rpx;
  font-size: 26rpx; color: #A09888;
}
.load-end { color: #C4BCB3; }

/* ========== 空状态 ========== */
.empty {
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  padding: 100rpx 32rpx; gap: 12rpx;
}
.empty__icon { font-size: 80rpx; }
.empty__text { font-size: 30rpx; color: #6B6255; font-weight: 500; }
.empty__sub { font-size: 26rpx; color: #A09888; }

/* ========== 底部安全区 ========== */
.safe-bottom { height: calc(160rpx + env(safe-area-inset-bottom)); }

/* ========== 悬浮发布按钮 ========== */
.fab {
  position: fixed;
  right: 36rpx;
  bottom: 180rpx;
  width: 104rpx; height: 104rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #E8A840, #F0B850);
  box-shadow: 0 8rpx 28rpx rgba(232,168,64,0.40);
  display: flex; align-items: center; justify-content: center;
  z-index: 80;
  transition: transform 0.2s;
}
.fab:active { transform: scale(0.88); }
.fab__icon {
  font-size: 56rpx; color: #fff; font-weight: 300; line-height: 1;
}

/* ========== 热门推荐（横滑）========== */
.hot-strip {
  margin: 24rpx 24rpx 0;
  padding: 24rpx;
  background: #fff;
  border-radius: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(44,36,22,0.04);
}
.hot-strip__head {
  display: flex; align-items: center; justify-content: space-between;
  margin-bottom: 18rpx;
}
.hot-strip__title { font-size: 30rpx; font-weight: 600; color: #2C2416; }
.hot-strip__more { font-size: 26rpx; color: #3D7A7C; font-weight: 500; }
.hot-strip__scroll { white-space: nowrap; }
.hot-strip__list { display: inline-flex; gap: 16rpx; }
.hot-card {
  flex-shrink: 0; width: 180rpx;
  display: flex; flex-direction: column; align-items: center;
}
.hot-card__img {
  width: 160rpx; height: 160rpx;
  border-radius: 16rpx; background: #E6E1DA;
}
.hot-card__name {
  width: 160rpx;
  font-size: 24rpx; color: #2C2416;
  margin-top: 10rpx;
  overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
  text-align: center;
}
