/* pages/wanted/wanted.wxss - 求购广场 · 湖畔晨光 */

.page-container {
  padding-bottom: 32rpx;
  background: var(--color-bg-page);
}

/* 发布按钮区域 */
.publish-section {
  padding: 24rpx 32rpx;
  background: var(--color-bg-card);
  margin-bottom: 12rpx;
}

/* Tab 切换 */
.tab-section {
  display: flex;
  background: var(--color-bg-card);
  margin-bottom: 12rpx;
  border-bottom: 1rpx solid var(--color-border-light);
}

.tab-item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 92rpx;
  font-size: 30rpx;
  color: var(--color-text-secondary);
  position: relative;
  transition: color var(--transition-fast);
}

.tab-item--active {
  color: var(--color-primary);
  font-weight: 600;
}

.tab-item--active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 5rpx;
  background: var(--color-primary);
  border-radius: var(--radius-full);
}

/* 求购列表 */
.wanted-list {
  padding: 0 24rpx;
}

.wanted-card {
  position: relative;
  background: var(--color-bg-card);
  border-radius: var(--radius-xl);
  padding: 24rpx;
  margin-bottom: 18rpx;
  box-shadow: var(--shadow-xs);
}

/* 状态标签 */
.wanted-status {
  position: absolute;
  right: 24rpx;
  top: 24rpx;
  padding: 6rpx 16rpx;
  border-radius: var(--radius-full);
  font-size: 22rpx;
  font-weight: 500;
}

.status--open {
  background: var(--color-success-bg);
  color: var(--color-success);
}

.status--responded {
  background: var(--color-warning-bg);
  color: var(--color-warning);
}

.status--closed {
  background: var(--color-bg-tag);
  color: var(--color-text-tertiary);
}

.wanted-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  margin-bottom: 14rpx;
  padding-right: 120rpx;
}

.wanted-budget {
  display: flex;
  align-items: center;
  margin-bottom: 14rpx;
}

.budget-label {
  font-size: 28rpx;
  color: var(--color-text-secondary);
  margin-right: 8rpx;
}

.budget-value {
  font-size: 28rpx;
  color: var(--color-price);
  font-weight: 600;
}

.wanted-description {
  display: block;
  font-size: 28rpx;
  color: var(--color-text-secondary);
  line-height: 1.6;
  margin-bottom: 14rpx;
  max-height: 90rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.wanted-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.wanted-meta {
  display: flex;
  align-items: center;
  gap: 14rpx;
  font-size: 26rpx;
  color: var(--color-text-tertiary);
}

.meta-location,
.meta-time {
  font-size: 26rpx;
}

.respond-btn {
  flex-shrink: 0;
  width: 240rpx;
  height: 76rpx;
  font-size: 28rpx;
}

/* 加载与空状态 */
.loading-more { display:flex; align-items:center; justify-content:center; padding:32rpx; font-size:26rpx; color:var(--color-text-tertiary); }
.no-more { display:flex; align-items:center; justify-content:center; padding:32rpx; font-size:26rpx; color:var(--color-text-tertiary); }
.empty-state { display:flex; flex-direction:column; align-items:center; justify-content:center; padding:80rpx 32rpx; }
.empty-image { width:280rpx; height:280rpx; margin-bottom:28rpx; opacity:0.8; }
.empty-text { font-size:30rpx; color:var(--color-text-tertiary); margin-bottom:10rpx; }
.empty-subtext { font-size:26rpx; color:var(--color-text-tertiary); }
