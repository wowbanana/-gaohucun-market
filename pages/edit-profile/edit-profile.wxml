<!-- pages/edit-profile/edit-profile.wxml - 编辑个人资料页 -->
<view class="edit-profile-page">
  <!-- 头像 -->
  <view class="avatar-section" bindtap="onChangeAvatar">
    <image class="avatar" src="{{avatarUrl || '/images/default-avatar.png'}}" mode="aspectFill" />
    <view class="avatar-edit-hint">
      <text>点击更换头像</text>
      <text class="edit-icon">📷</text>
    </view>
  </view>

  <!-- 表单 -->
  <view class="form-section">
    <!-- 昵称 -->
    <view class="form-item">
      <text class="form-label">昵称</text>
      <input
        class="form-input"
        placeholder="请输入昵称"
        maxlength="20"
        value="{{nickname}}"
        bindinput="onNicknameInput"
      />
    </view>

    <!-- 手机号 -->
    <view class="form-item">
      <text class="form-label">手机号</text>
      <input
        class="form-input"
        placeholder="请输入手机号"
        type="number"
        maxlength="11"
        value="{{phone}}"
        bindinput="onPhoneInput"
      />
    </view>

  </view>

  <!-- 保存按钮 -->
  <view class="save-section">
    <button
      class="save-btn {{hasChanged ? '' : 'disabled'}}"
      loading="{{submitting}}"
      disabled="{{submitting || !hasChanged}}"
      bindtap="onSave"
    >
      保存修改
    </button>
  </view>
</view>
