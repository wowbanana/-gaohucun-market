/* pages/edit-profile/edit-profile.wxss - 编辑个人资料 · 湖畔晨光 */

.edit-profile-page {
  min-height: 100vh;
  background: var(--color-bg-page);
}

.avatar-section {
  display: flex; flex-direction: column; align-items: center;
  padding: 48rpx 0 32rpx;
  background: var(--color-bg-card);
  margin-bottom: 12rpx;
}

.avatar {
  width: 160rpx; height: 160rpx; border-radius: 50%;
  border: 3rpx solid var(--color-border-light);
}

.avatar-edit-hint {
  display: flex; align-items: center; margin-top: 12rpx;
  font-size: 24rpx; color: var(--color-text-tertiary);
}

.edit-icon { margin-left: 6rpx; font-size: 24rpx; }

.form-section {
  background: var(--color-bg-card);
  padding: 0 30rpx;
}

.form-item {
  display: flex; align-items: center; padding: 26rpx 0;
  border-bottom: 1rpx solid var(--color-border-light);
}

.form-label {
  width: 140rpx; font-size: 28rpx; color: var(--color-text-secondary); flex-shrink: 0;
}

.form-input { flex: 1; font-size: 28rpx; color: var(--color-text-primary); text-align: right; }

.phone-row {
  flex: 1; display: flex; align-items: center; justify-content: flex-end; gap: 14rpx;
}

.phone-input { flex: 1; text-align: right; }

.get-phone-btn {
  font-size: 22rpx; color: var(--color-primary); background: var(--color-primary-light);
  padding: 6rpx 16rpx; border-radius: var(--radius-full); border: none; line-height: 1.4; white-space: nowrap;
}

.get-phone-btn::after { border: none; }

.picker-value {
  flex: 1; font-size: 28rpx; color: var(--color-text-primary); text-align: right;
  display: flex; align-items: center; justify-content: flex-end;
}

.picker-value.placeholder { color: var(--color-text-tertiary); }
.picker-arrow { font-size: 28rpx; color: var(--color-text-tertiary); margin-left: 8rpx; }

.save-section { padding: 60rpx 30rpx; }

.save-btn {
  width: 100%; height: 96rpx;
  background: var(--color-primary-gradient);
  color: #FFFFFF; font-size: 32rpx; font-weight: 600;
  border-radius: var(--radius-full);
  display: flex; align-items: center; justify-content: center;
  border: none; box-shadow: var(--shadow-glow);
}

.save-btn.disabled {
  background: var(--color-bg-tag);
  box-shadow: none;
}

.save-btn::after { border: none; }
