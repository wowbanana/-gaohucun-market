/* pages/chat/chat.wxss - 聊天页 · 湖畔晨光 */

.chat-page {
  display: flex; flex-direction: column; height: 100vh;
  background: var(--color-bg-page); overflow-x: hidden;
}

.message-list {
  flex: 1; padding: 20rpx 24rpx; overflow-y: auto; overflow-x: hidden;
  width: 100%; box-sizing: border-box;
}

.goods-card {
  display: flex; align-items: center; background: var(--color-bg-card);
  border-radius: var(--radius-xl); padding: 14rpx 18rpx; margin-bottom: 22rpx;
  box-shadow: var(--shadow-xs);
}

.goods-thumb {
  width: 80rpx; height: 80rpx; border-radius: var(--radius-md);
  margin-right: 14rpx; flex-shrink: 0; background: var(--color-bg-tag);
}

.goods-brief { flex: 1; overflow: hidden; }
.goods-brief-title { display: block; font-size: 26rpx; color: var(--color-text-primary); overflow: hidden; white-space: nowrap; text-overflow: ellipsis; }
.goods-brief-price { display: block; font-size: 24rpx; color: var(--color-price); margin-top: 4rpx; }
.goods-brief-arrow { font-size: 28rpx; color: var(--color-text-tertiary); margin-left: 10rpx; }

.message-item { display: flex; align-items: flex-start; margin-bottom: 22rpx; width: 100%; }
.message-self { flex-direction: row; justify-content: flex-end; }

.msg-avatar { width: 72rpx; height: 72rpx; border-radius: 50%; flex-shrink: 0; background: var(--color-bg-tag); }

.msg-bubble {
  padding: 14rpx 20rpx; border-radius: var(--radius-lg);
  word-break: break-all;
}
.message-other .msg-bubble { margin-left: 14rpx; }
.message-self .msg-bubble { margin-right: 14rpx; }

.msg-bubble-other { background: var(--color-bg-card); border-top-left-radius: 4rpx; }
.msg-bubble-self { background: var(--color-primary); border-top-right-radius: 4rpx; }
.msg-bubble-self .msg-text { color: #FFFFFF; }

.msg-text { font-size: 30rpx; line-height: 1.6; color: var(--color-text-primary); }

/* 消息体（气泡 + 时间戳） */
.msg-body { display: flex; flex-direction: column; max-width: 60%; }
.msg-body-self { align-items: flex-end; }

.msg-time {
  font-size: 22rpx; color: var(--color-text-tertiary);
  margin-top: 6rpx; padding: 0 4rpx;
}
.message-other .msg-time { align-self: flex-start; }
.message-self .msg-time { align-self: flex-end; }

.message-bottom-space { height: 20rpx; }

.input-bar {
  display: flex; align-items: center; padding: 14rpx 24rpx;
  padding-bottom: calc(14rpx + env(safe-area-inset-bottom));
  background: var(--color-bg-card); border-top: 1rpx solid var(--color-border-light);
}

.msg-input {
  flex: 1; height: 72rpx; background: var(--color-bg-input);
  border-radius: var(--radius-full); padding: 0 26rpx; font-size: 30rpx; margin-right: 14rpx;
}

.send-btn {
  width: 116rpx; height: 72rpx; display: flex; align-items: center;
  justify-content: center; background: var(--color-border);
  border-radius: var(--radius-full); font-size: 28rpx; color: var(--color-text-tertiary); flex-shrink: 0;
}

.send-btn-active { background: var(--color-primary); color: #FFFFFF; }
