/* pages/my-goods/my-goods.wxss - 我的发布 · 湖畔晨光 */

.my-goods-page {
  min-height: 100vh;
  background: var(--color-bg-page);
}

.tab-bar {
  display: flex;
  background: var(--color-bg-card);
  padding: 0 24rpx;
  border-bottom: 1rpx solid var(--color-border-light);
}

.tab-item {
  flex: 1; text-align: center; padding: 22rpx 0;
  font-size: 28rpx; color: var(--color-text-secondary); position: relative;
}

.tab-item.active {
  color: var(--color-primary); font-weight: 600;
}

.tab-item.active::after {
  content: '';
  position: absolute; bottom: 0; left: 50%; transform: translateX(-50%);
  width: 40rpx; height: 5rpx; background: var(--color-primary); border-radius: var(--radius-full);
}

.goods-list { padding: 16rpx; }

.goods-card {
  display: flex; background: var(--color-bg-card); border-radius: var(--radius-xl);
  padding: 20rpx; margin-bottom: 14rpx; position: relative; box-shadow: var(--shadow-xs);
}

.goods-image {
  width: 180rpx; height: 180rpx; border-radius: var(--radius-md); flex-shrink: 0;
  background: var(--color-bg-tag);
}

.goods-info {
  flex: 1; margin-left: 20rpx; display: flex; flex-direction: column; justify-content: space-between;
}

.goods-title {
  font-size: 28rpx; color: var(--color-text-primary); font-weight: 500;
  display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;
}

.goods-price-row { display: flex; align-items: baseline; }

.goods-price { font-size: 30rpx; font-weight: 700; color: var(--color-price); }
.goods-unit { font-size: 22rpx; color: var(--color-text-tertiary); }
.goods-time { font-size: 22rpx; color: var(--color-text-tertiary); }

.goods-actions {
  position: absolute; bottom: 20rpx; right: 20rpx; display: flex; gap: 10rpx;
}

.action-btn {
  padding: 6rpx 18rpx; border-radius: var(--radius-full); font-size: 22rpx; font-weight: 500;
}

.action-btn.primary { background: var(--color-primary-light); color: var(--color-primary); }
.action-btn.success { background: var(--color-success-bg); color: var(--color-success); }
.action-btn.danger { background: var(--color-danger-bg); color: var(--color-danger); }

.empty-state { display: flex; flex-direction: column; align-items: center; padding: 120rpx 0; }
.empty-icon { font-size: 80rpx; margin-bottom: 16rpx; }
.empty-text { font-size: 28rpx; color: var(--color-text-tertiary); margin-bottom: 24rpx; }
.empty-action {
  padding: 14rpx 40rpx; background: var(--color-primary); color: #FFFFFF;
  border-radius: var(--radius-full); font-size: 28rpx;
}

.loading-status { display: flex; align-items: center; justify-content: center; gap: 10rpx; padding: 30rpx 0; font-size: 26rpx; color: var(--color-text-tertiary); }
.loading-spinner {
  width: 32rpx; height: 32rpx; border: 3rpx solid var(--color-border-light);
  border-top-color: var(--color-primary); border-radius: 50%; animation: spin 0.8s linear infinite;
}
@keyframes spin { to { transform: rotate(360deg); } }
.no-more { text-align: center; padding: 30rpx 0; font-size: 24rpx; color: var(--color-text-tertiary); }
