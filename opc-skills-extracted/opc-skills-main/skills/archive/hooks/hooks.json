{
  "description": "Load .archive/MEMORY.md into session context at startup for cross-session knowledge reuse",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT:-${DROID_PLUGIN_ROOT}}/hooks/load-memory.py\""
          }
        ]
      }
    ]
  }
}
